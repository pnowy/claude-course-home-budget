{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(git status)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git checkout:*)",
      "Read(src/**)",
      "Edit(src/**)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "mcp__context7__*",
      "mcp__devdb-mcp-server__*"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "deny": [
      "Read(.env*)",
      "Bash(rm -rf *)"
    ]
  },
  "hooks": {
    "PostToolUse":[
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$(date) lint triggered\" >> /tmp/hook.log && npm run lint"
          }
        ]
      }
    ]
  }
}
